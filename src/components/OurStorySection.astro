---
import { Picture } from 'astro:assets';

import garlicNaanImg from '../assets/GarlicNaan.webp';
---

<section
  id="philosophy"
  class="py-24 md:py-32 bg-surface-container-low relative transition-colors duration-500"
>
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
    <div class="space-y-8">
      <h2 class="text-[1.875rem] md:text-display-md text-on-surface">
        What makes our story unique?
      </h2>
      <div class="text-body-md text-on-surface-variant space-y-4">
        <p>
          Spice Grill & Bar is the premier destination for authentic Punjabi cuisine in Ash Fork,
          blending traditional tandoor cooking with modern culinary excellence.
        </p>
        <p>
          Located on historic Route 66, we offer a unique dining experience led by chefs with
          decades of expertise, ensuring every dish captures the true essence of India.
        </p>
      </div>
      <div class="grid grid-cols-2 gap-8 pt-8 mt-8">
        <div class="bg-surface-container p-6 rounded-2xl text-center">
          <span class="block text-heading-lg text-primary-container">25+</span>
          <span class="text-label-sm text-on-surface-variant uppercase tracking-widest mt-2 block"
            >Signature Spices</span
          >
        </div>
        <div class="bg-surface-container p-6 rounded-2xl text-center">
          <span class="block text-heading-lg text-primary-container">900°F</span>
          <span class="text-label-sm text-on-surface-variant uppercase tracking-widest mt-2 block"
            >Clay Oven</span
          >
        </div>
      </div>
    </div>

    <div class="relative group cursor-pointer overflow-hidden rounded-2xl shadow-2xl">
      <Picture
        src={garlicNaanImg}
        alt="Tandoori Preparation"
        class="w-full aspect-[4/5] object-cover rounded-2xl lg:grayscale lg:group-hover:grayscale-0 transition-all duration-700 ease-out transform group-hover:scale-105"
        widths={[320, 640, 960, 1280, 1600]}
        sizes="(min-width: 1024px) 50vw, 100vw"
        formats={['avif', 'webp']}
        quality={60}
        decoding="async"
      />
      <div class="absolute bottom-6 left-6 right-6">
        <div class="glass p-4 rounded-xl">
          <p class="text-sm text-on-surface font-semibold">Freshly prepared</p>
          <p class="text-xs text-on-surface-variant">From tandoor to table</p>
        </div>
      </div>
    </div>
  </div>

  {/* Mission, Vision, Values */}
  <div class="max-w-7xl mx-auto px-6 mt-24 grid grid-cols-1 md:grid-cols-3 gap-8">
    <div
      class="bg-surface-container rounded-2xl p-8 hover:-translate-y-1 transition-transform duration-300"
    >
      <h3 class="text-heading-md text-primary-container mb-4">What is our mission?</h3>
      <p class="text-body-md text-on-surface-variant">
        To serve authentic Punjabi Indian cuisine while providing an exceptional dining experience
        that celebrates the rich culinary heritage of Punjab.
      </p>
    </div>
    <div
      class="bg-surface-container rounded-2xl p-8 hover:-translate-y-1 transition-transform duration-300"
    >
      <h3 class="text-heading-md text-primary-container mb-4">What is our vision?</h3>
      <p class="text-body-md text-on-surface-variant">
        To be the premier destination in Ash Fork for Punjabi cuisine, recognized for exceptional
        food, warm hospitality, and inviting atmosphere.
      </p>
    </div>
    <div
      class="bg-surface-container rounded-2xl p-8 hover:-translate-y-1 transition-transform duration-300"
    >
      <h3 class="text-heading-md text-primary-container mb-4">What are our core values?</h3>
      <p class="text-body-md text-on-surface-variant">
        Quality, authenticity, and customer satisfaction are the heart of our service, from
        ingredient selection to your table.
      </p>
    </div>
  </div>
</section>
