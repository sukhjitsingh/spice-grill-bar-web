---
import faqData from '../data/faq.json';
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="FAQ | Spice Grill & Bar"
  description="Frequently asked questions about Spice Grill & Bar. Information on hours, location, and vegetarian options."
>
  <main class="pt-32 pb-24 px-6 bg-surface-container-low min-h-screen">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-[1.875rem] md:text-display-md text-center text-on-surface mb-16">
        Frequently Asked <span class="text-primary-container">Questions</span>
      </h1>

      <div class="space-y-4">
        {
          faqData.map((item) => (
            <div class="bg-surface-container p-8 rounded-2xl">
              <h3 class="text-heading-md text-on-surface mb-3">{item.question}</h3>
              <p class="text-body-md text-on-surface-variant">{item.answer}</p>
            </div>
          ))
        }
      </div>
    </div>
  </main>
</Layout>
