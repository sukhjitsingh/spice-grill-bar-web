---
import { Quote, Star } from 'lucide-react';

import reviewsData from '../data/reviews.json';

// Define interface matching our JSON
interface Review {
  id: string;
  author: string;
  rating: number;
  text: string;
  source: 'Google' | 'Yelp';
  date: string;
  avatar?: string;
}

// Duplicate reviews for seamless marquee
const reviews: Review[] = [...reviewsData, ...reviewsData, ...reviewsData] as Review[];
---

<section class="py-24 bg-surface-dim relative overflow-hidden">
  <div class="container mx-auto px-6 mb-12 text-center relative z-10">
    <h2 class="text-heading-lg text-on-surface mb-6">
      What Our <span class="text-primary-container">Guests Say</span>
    </h2>
    <p class="text-body-lg text-on-surface-variant max-w-2xl mx-auto">
      We love hearing from our community. Here are some of the latest reviews from Google and Yelp.
    </p>
  </div>

  {/* Marquee Container */}
  <div class="relative w-full overflow-hidden group/marquee">
    {/* Gradient Masks */}
    <div
      class="absolute left-0 top-0 bottom-0 w-32 z-20 bg-gradient-to-r from-surface-dim to-transparent pointer-events-none"
    >
    </div>
    <div
      class="absolute right-0 top-0 bottom-0 w-32 z-20 bg-gradient-to-l from-surface-dim to-transparent pointer-events-none"
    >
    </div>

    <div class="flex animate-marquee">
      {
        reviews.map((review) => (
          <div class="w-[340px] md:w-[380px] h-[280px] flex-shrink-0 mx-3 relative group">
            <div class="h-full p-6 rounded-2xl relative overflow-hidden flex flex-col bg-surface-container transition-all duration-300">
              <Quote
                className="absolute top-5 right-5 w-12 h-12 text-primary-container/15 group-hover:text-primary-container/25 transition-colors duration-300 rotate-180"
                aria-hidden="true"
              />

              <div class="absolute inset-0 bg-gradient-to-br from-primary-container/0 to-secondary-container/0 group-hover:from-primary-container/5 group-hover:to-secondary-container/5 transition-all duration-500 pointer-events-none rounded-2xl" />

              <div class="flex justify-between items-start mb-4 relative z-10">
                <div class="flex items-center gap-3">
                  <div class="flex-shrink-0">
                    <div class="w-12 h-12 rounded-full bg-surface-container-high flex items-center justify-center text-on-surface font-bold text-lg">
                      {review.author.charAt(0).toUpperCase()}
                    </div>
                  </div>
                  <div class="min-w-0">
                    <p class="font-semibold text-on-surface leading-tight truncate">
                      {review.author}
                    </p>
                    <span class="text-xs text-on-surface-variant">{review.date}</span>
                  </div>
                </div>

                <div
                  class:list={[
                    'text-xs px-2.5 py-1.5 rounded-full font-semibold flex-shrink-0 relative z-20',
                    review.source === 'Google'
                      ? 'bg-blue-100 dark:bg-blue-500/20 border border-blue-300 dark:border-blue-500/40 text-blue-700 dark:text-blue-300'
                      : 'bg-red-100 dark:bg-red-500/20 border border-red-300 dark:border-red-500/40 text-red-700 dark:text-red-300',
                  ]}
                >
                  {review.source}
                </div>
              </div>

              <div class="flex gap-1 mb-4 relative z-10">
                {Array.from({ length: 5 }).map((_, i) => (
                  <Star
                    className={`w-4 h-4 ${i < review.rating ? 'fill-primary-container text-primary-container' : 'text-outline-variant'}`}
                    aria-hidden="true"
                  />
                ))}
                <span class="sr-only">{review.rating} out of 5 stars</span>
              </div>

              <div class="flex-1 relative z-10 overflow-hidden">
                <p class="text-on-surface-variant text-sm leading-relaxed line-clamp-4">
                  &ldquo;{review.text}&rdquo;
                </p>
              </div>

              <div class="absolute bottom-0 left-0 right-0 h-12 bg-gradient-to-t from-surface-container/90 to-transparent pointer-events-none rounded-b-2xl" />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-33.333%);
    }
  }
  .animate-marquee {
    animation: marquee 20s linear infinite;
    will-change: transform;
  }
  .group\/marquee:hover .animate-marquee {
    animation-play-state: paused;
  }
</style>
