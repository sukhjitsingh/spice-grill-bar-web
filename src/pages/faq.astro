---
import type { FAQItem } from '../types/faq';

import faqData from '../data/faq.json';
import Layout from '../layouts/Layout.astro';

const items = faqData as FAQItem[];
---

<Layout
  title="FAQ | Spice Grill & Bar"
  description="34 FAQs covering hours, menu, vegetarian and vegan options, takeout, payment, parking, and prices at Spice Grill & Bar — I-40 Exit 146, Ash Fork, AZ. Biker-friendly Indian restaurant on Route 66, 78 miles from the Grand Canyon."
  ogTitle="FAQ | Spice Grill & Bar — Common Questions Answered"
  ogDescription="Find answers to common questions about Spice Grill & Bar — hours, location, menu, vegetarian options, and more."
>
  <main class="pt-32 pb-24 px-6 bg-surface-container-low min-h-screen">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-[1.875rem] md:text-display-md text-center text-on-surface mb-16">
        Frequently Asked <span class="text-primary-container">Questions</span>
      </h1>

      <p class="speakable-faq-intro text-body-lg text-on-surface-variant mb-8">
        Spice Grill &amp; Bar is an authentic Indian restaurant at I-40 Exit 146 in Ash Fork,
        Arizona on historic Route 66. This page answers common questions about our hours, menu,
        vegetarian and vegan options, takeout, and location. Find the answer you need below.
      </p>

      <div id="faq-list" class="space-y-4">
        {
          items.map((item) => (
            <div class="bg-surface-container p-8 rounded-2xl">
              <h2 class="text-heading-md text-on-surface mb-3">{item.question}</h2>
              <p class="speakable-faq-answer text-body-md text-on-surface-variant">{item.answer}</p>
              {item.relatedLink && (
                <a
                  href={item.relatedLink.href}
                  class="inline-block mt-3 text-sm text-primary-container underline underline-offset-2 hover:opacity-80 transition-opacity"
                >
                  → {item.relatedLink.text}
                </a>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </main>

  <!-- Speakable schema markup — targets intro paragraph for voice extraction -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "url": "https://spicegrillbar66.com/faq/",
      "name": "FAQ | Spice Grill & Bar",
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".speakable-faq-intro", ".speakable-faq-answer"]
      }
    }
  </script>
</Layout>
