{
  "entry": ["src/pages/**/*.astro"],
  "project": ["src/**/*.{ts,tsx,astro}"],
  "ignore": ["**/*.d.ts", "postcss.config.cjs", "src/components/ui/**", ".github/**"],
  "ignoreDependencies": [
    "sharp",
    "@astrojs/check",
    "typescript",
    "eslint-config-airbnb-typescript",
    "postcss",
    "eslint-plugin-import",
    "eslint-plugin-react",
    "eslint-plugin-react-hooks",
    "eslint-config-airbnb-base",
    "@radix-ui/react-label",
    "@radix-ui/react-separator",
    "tailwindcss",
    "tw-animate-css",
    "react-dom",
    "@types/react-dom",
    "@playwright/test",
    "axe-core",
    "@axe-core/cli",
    "@commitlint/cli",
    "@lhci/cli",
    "eslint",
    "lint-staged"
  ],
  "ignoreExportsUsedInFile": true,
  "ignoreBinaries": [
    "astro",
    "axe",
    "lhci",
    "eslint",
    "simple-git-hooks",
    "prettier",
    "tsc",
    "knip",
    "lint-staged",
    "commitlint",
    "playwright"
  ]
}
