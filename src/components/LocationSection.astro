---
import { GoogleMap } from './GoogleMap';

const API_KEY = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY;
---

<section id="location" class="py-24 bg-surface-container transition-colors duration-500">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-12 text-center">
      <h2 class="text-heading-lg text-on-surface mb-4">Find Us on Historic Route 66</h2>
      <p class="text-body-md text-on-surface-variant max-w-2xl mx-auto">
        Located in the heart of Ash Fork, AZ. The perfect pitstop for hungry travelers
        <a href="/near-grand-canyon/" class="text-primary-container underline underline-offset-2 hover:opacity-80 transition-opacity">heading to the Grand Canyon</a>
        or riding historic Route 66. Need directions?
        <a href="/directions/" class="text-primary-container underline underline-offset-2 hover:opacity-80 transition-opacity">Step-by-step driving directions from Flagstaff, Williams, and Las Vegas.</a>
        <br />
        <span class="text-primary-container font-medium">Biker and Family Friendly!</span>
      </p>
    </div>

    <div class="bg-surface-container-high rounded-2xl overflow-hidden">
      <div class="w-full h-[400px] md:h-[500px] rounded-xl overflow-hidden">
        <GoogleMap apiKey={API_KEY} client:visible={{ rootMargin: '200px' }} />
      </div>
    </div>
  </div>
</section>
