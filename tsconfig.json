{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "src/**/*"],
  "exclude": [
    "dist/**/*",
    "dist-dark/**/*",
    "node_modules/**/*",
    ".lighthouseci/**/*",
    "reports/**/*",
    "test-results/**/*"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  }
}
